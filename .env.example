# ─────────────────────────────────────────────────────────────────────────────
# ProofForge — Environment Variables
# Copy this file to .env and fill in your values.
# .env is never committed — see .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:8000/api/v1/auth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Connection URL used by the FastAPI app (Docker service name "postgres")
DATABASE_URL=postgresql://proofforge:password@postgres:5432/proofforge
# Individual vars used by the postgres Docker container
POSTGRES_USER=proofforge
POSTGRES_PASSWORD=password
POSTGRES_DB=proofforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=miniopassword

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRE_HOURS=24

# ── Portfolio Card Ed25519 Signing ────────────────────────────────────────────
# Generate with PyNaCl:
#   from nacl.signing import SigningKey; import base64
#   sk = SigningKey.generate()
#   print("Private:", base64.b64encode(bytes(sk)).decode())
#   print("Public: ", base64.b64encode(bytes(sk.verify_key)).decode())
PORTFOLIO_SIGNING_PRIVATE_KEY=
PORTFOLIO_SIGNING_PUBLIC_KEY=

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_TEMP_DIR=/tmp/submissions

# ── Dev/testing helpers — keep disabled in production ────────────────────────
# DEV_MODE=true enables POST /auth/dev-login (the "Testing" button on the login page)
DEV_MODE=false
# Review provider: anthropic (default) | openai_compat (free: Groq/Gemini/OpenRouter) | mock (no key)
REVIEW_PROVIDER=anthropic
DEV_LLM_BASE_URL=https://api.groq.com/openai/v1
DEV_LLM_API_KEY=
DEV_LLM_MODEL=llama-3.3-70b-versatile
